# Dockerfile for Production
# Multi-stage build to optimize size and security

# Stage 1: Build stage
FROM maven:3.9.6-eclipse-temurin-21-alpine AS builder
WORKDIR /app

# Arguments for GitHub credentials
ARG GITHUB_USERNAME
ARG GITHUB_TOKEN

# Copy pom.xml first to leverage Maven's cache
COPY pom.xml .
COPY .mvn .mvn

# Download dependencies with credentials passed as arguments
RUN mvn dependency:go-offline -s .mvn/settings.xml -Dgithub.username="${GITHUB_USERNAME}" -Dgithub.token="${GITHUB_TOKEN}"

# Copy source code and compile
COPY src src
RUN mvn package -DskipTests -s .mvn/settings.xml -Dgithub.username="${GITHUB_USERNAME}" -Dgithub.token="${GITHUB_TOKEN}"

# Stage 2: Runtime stage
FROM eclipse-temurin:21.0.2_13-jre-alpine
WORKDIR /app

# Create a non-privileged user to run the application
RUN addgroup -S appgroup && adduser -S appuser -G appgroup
USER appuser

# Copy the compiled JAR from the previous stage
COPY --from=builder /app/target/*.jar app.jar

# Define environment variables
ENV SPRING_PROFILES_ACTIVE=prod
ENV JAVA_OPTS="-Xms512m -Xmx1g -XX:+UseG1GC"

EXPOSE 8080
ENTRYPOINT ["java", "-jar", "app.jar"]